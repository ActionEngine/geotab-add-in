# Database connections
DATABASE_URL=postgresql+asyncpg://user:password@db:5432/geotab_db

# Database credentials (for Docker setup)
DB_HOST=db
DB_PORT=5432
DB_USER=user
DB_PASSWORD=password
DB_NAME=geotab_db

# JWT secret key (generate with: openssl rand -hex 32)
JWT_SECRET=your-secret-key-here

# Ingestion settings
INGESTION_DAYS_LIMIT=3
# Validation time window in minutes to check for recent data
RECENT_WINDOW_MINUTES=15

# CORS origins (comma-separated)
ALLOWED_ORIGINS=https://my.geotab.com,https://main.d14o3o9kbo1n4h.amplifyapp.com,http://localhost:5173,https://localhost:5173

# Allowed users (comma-separated, e.g. user1@example.com,user2@example.com). Leave empty to allow all users.
ALLOWED_USERS=

# Log Level
LOG_LEVEL=ERROR